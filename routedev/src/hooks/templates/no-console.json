{
  "id": "no-console",
  "name": "禁止 console.log",
  "description": "保存文件后检测是否包含 console.log 调试语句",
  "matchKeywords": ["console", "console.log", "调试", "debug", "日志"],
  "event": "post-tool-call",
  "condition": { "toolName": "file_write" },
  "command": "grep -n \"console\\.log\" {{filePath}} && echo 'CONSOLE_LOG_FOUND' || true",
  "failBehavior": "warn"
}
