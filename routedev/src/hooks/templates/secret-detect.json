{
  "id": "secret-detect",
  "name": "敏感信息检测",
  "description": "保存文件后检测是否包含 API Key、密码等敏感信息",
  "matchKeywords": ["敏感信息", "secret", "密钥", "密码", "api key", "token", "credential"],
  "event": "post-tool-call",
  "condition": { "toolName": "file_write" },
  "command": "grep -E \"(api[_-]?key|password|secret|token)\\s*[=:]\\s*['\\\"][^'\\\"]+['\\\"]\" {{filePath}} && echo 'SECRET_DETECTED' || true",
  "failBehavior": "block"
}
