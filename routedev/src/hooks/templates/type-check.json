{
  "id": "type-check",
  "name": "类型检查",
  "description": "保存 TypeScript 文件后运行 tsc --noEmit 类型检查",
  "matchKeywords": ["类型", "type", "typescript", "tsc", "类型检查"],
  "event": "post-tool-call",
  "condition": { "toolName": "file_write", "filePattern": "\\.(ts|tsx)$" },
  "command": "npx tsc --noEmit",
  "failBehavior": "warn"
}
